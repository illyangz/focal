{
  "name": "focal",
  "version": "1.0.1",
  "description": "Beautiful screen recordings with automatic zoom",
  "license": "UNLICENSED",
  "author": "Focal",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.focal.app",
    "productName": "Focal",
    "files": [
      "main.js",
      "preload.js",
      "renderer.html",
      "overlay.html",
      "overlay-preload.js",
      "package.json",
      "build/icon.png",
      "build/Video Icons.png",
      "native/focal_capture"
    ],
    "asarUnpack": [
      "native/focal_capture"
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "https://pub-7edefd65576445868402946157f473b1.r2.dev",
        "channel": "latest"
      }
    ],
    "mac": {
      "category": "public.app-category.video",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null,
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "build/icon.png"
    },
    "dmg": {
      "artifactName": "Focal-Mac.dmg"
    },
    "nsis": {
      "artifactName": "Focal-Windows-Setup.exe"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "optionalDependencies": {
    "uiohook-napi": "^1.5.4"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
